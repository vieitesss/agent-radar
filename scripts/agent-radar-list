#!/usr/bin/env sh
set -eu

command -v tmux >/dev/null 2>&1 || exit 0

rows() {
    tmux show-environment -g 2>/dev/null |
    awk -F= -v now="$(date +%s)" '
function remember(suffix, arr, key, val, pane) {
    if (key ~ ("_" suffix "$")) {
        pane = key
        sub(/^TMUX_AGENT_RADAR_PANE_/, "", pane)
        sub("_" suffix "$", "", pane)
        arr[pane] = val
        panes[pane] = 1
    }
}
{
    key = $1
    val = $0
    sub(/^[^=]*=/, "", val)
    remember("AGENT", agent, key, val)
    remember("TARGET", target, key, val)
    remember("STATE", state, key, val)
    remember("STOPPED_AT", stopped_at, key, val)
    remember("SEEN_STOPPED_AT", seen_at, key, val)
}
END {
    for (pane in panes) {
        if (agent[pane] == "" || target[pane] == "") continue
        s = state[pane] == "" ? "running" : state[pane]
        # Three tiers: unseen-stopped (needs you) > running > seen-stopped
        # (focused after stopping = handled). seen when SEEN_STOPPED_AT caught
        # up to STOPPED_AT (set by agent-radar-status on session focus).
        if (s == "stopped") {
            seen = (seen_at[pane] != "" && seen_at[pane] == stopped_at[pane])
            tier = seen ? 2 : 0
            dot = seen ? "\033[32m●\033[0m" : "\033[31m●\033[0m"
        } else {
            tier = 1
            dot = "\033[33m●\033[0m"
        }
        # Secondary sort, compared only within a tier (rows partition on tier
        # first). Unseen: oldest-first, so zero-pad stopped_at for lexical=numeric
        # ascending. Running + seen: alphabetical by target.
        if (tier == 0 && stopped_at[pane] ~ /^[0-9]+$/)
            sortkey = sprintf("%012d", stopped_at[pane])
        else
            sortkey = target[pane]
        age = ""
        if (s == "stopped" && stopped_at[pane] ~ /^[0-9]+$/) {
            delta = now - stopped_at[pane]
            age = delta < 60 ? delta "s" : int(delta / 60) "m"
        }
        display = dot " " agent[pane] " " target[pane]
        if (age != "") display = display " " age
        print tier "|" sortkey "|" display "|" pane
    }
}' |
    sort -t '|' -k1,1n -k2,2
}

if [ "${1:-}" = rows ]; then
    rows
    exit 0
fi

command -v fzf >/dev/null 2>&1 || { tmux display-message 'agent-radar: fzf not found'; exit 0; }

rows=$(rows)
[ -n "$rows" ] || { tmux display-message 'agent-radar: no agent panes'; exit 0; }

refresh_interval=$(tmux show-option -gqv @agent-radar-poll-interval 2>/dev/null || true)
case "$refresh_interval" in
    ''|*[!0-9]*) refresh_interval=2 ;;
esac
[ "$refresh_interval" -gt 0 ] || refresh_interval=1
script_path=$(CDPATH= cd "$(dirname "$0")" && pwd -P)/$(basename "$0")
refresh_cmd='"$AGENT_RADAR_LIST" rows; sleep '"$refresh_interval"

selected=$(
    printf '%s\n' "$rows" |
    AGENT_RADAR_LIST=$script_path FZF_DEFAULT_OPTS= FZF_DEFAULT_OPTS_FILE= fzf --ansi --layout=reverse \
        --delimiter='|' --with-nth=3 --track --id-nth=4 \
        --bind "load:reload($refresh_cmd)" || true
)
[ -n "$selected" ] || exit 0

pane=$(printf '%s' "$selected" | awk -F '|' '{print $4}')
session=$(tmux display-message -p -t "$pane" '#{session_name}' 2>/dev/null || true)
window=$(tmux display-message -p -t "$pane" '#{window_id}' 2>/dev/null || true)

[ -n "$session" ] && [ -n "$window" ] || { tmux display-message 'agent-radar: pane disappeared'; exit 0; }

tmux switch-client -t "$session"
tmux select-window -t "$window"
tmux select-pane -t "$pane"
