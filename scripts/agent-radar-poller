#!/usr/bin/env sh
set -eu

command -v tmux >/dev/null 2>&1 || exit 0
script_dir=$(CDPATH= cd "$(dirname "$0")" && pwd -P) || exit 0
store_cmd=$script_dir/agent-radar-store

opt() {
    v=$(tmux show-option -gqv "$1" 2>/dev/null || true)
    [ -n "$v" ] && printf '%s\n' "$v" || printf '%s\n' "$2"
}

pid_val() {
    tmux show-option -gqv @agent-radar-pid 2>/dev/null || true
}

pid_set() {
    tmux set-option -gq @agent-radar-pid "$1"
}

pid_unset() {
    owner=${1:-}
    if [ -n "$owner" ] && [ "$(pid_val)" != "$owner" ]; then
        return 0
    fi
    tmux set-option -gqu @agent-radar-pid 2>/dev/null || true
}

# Read the last_change|armed|state hot-loop fields for a pane in ONE awk pass.
# ponytail: consumes the store's own records() pipe format (key format stays in
# the store); a per-field store subcommand would refork tmux and undo 011's
# latency win, so the poller reads the shared records snapshot locally instead.
record_hot() {
    awk -F '|' -v pane="$1" '$1 == pane { print $4 "|" $5 "|" $6; exit }' "$records_file"
}

set_pane() {
    AGENT_RADAR_STORE_RECORDS_FILE=$records_file "$store_cmd" set "$@"
}

clear_pane() {
    "$store_cmd" clear "$1"
}

# True when the pane visibly shows the agent working indicator. This is how herdr
# does it: match the live working indicator, not a screen diff and not text
# hints. The braille progress glyph only exists while the agent animates it, so
# it can't collide with transcript prose that merely quotes "Working..." or
# "esc to interrupt" (that quoting is exactly what produced false positives).
# Matched byte-wise under LC_ALL=C so it's locale-proof: any braille codepoint
# U+2800-U+28FF is E2 followed by A0-A3, and box-drawing (E2 94..) can't match.
# opencode doesn't animate braille; its working indicator is a pulsing progress bar
# of filled/dim squares (U+25A0 = E2 96 A0, U+2B1D = E2 AC 9D), so the default
# also matches a run of 4+ of those. A 4-long square run can't occur in prose.
# ponytail: an agent whose working indicator is neither braille nor a square bar
# won't be detected -- override @agent-radar-working-pattern with its own marker.
# Capture WITHOUT -e (no SGR escapes): opencode colors each square of its
# progress bar individually, so with -e the per-cell color codes split the
# run below 4 and mixed-color frames miss -> false "stopped". Plain text keeps
# the glyphs contiguous; braille glyphs are single-color so this is a no-op
# for pi/claude/codex.
detect_working() {
    LC_ALL=C tmux capture-pane -pJ -t "$1" 2>/dev/null | LC_ALL=C grep -qE "$work_re"
}

agent_for_tty() {
    tty=${1#/dev/}
    allow=$2

    ps -t "$tty" -o comm= 2>/dev/null | while IFS= read -r comm; do
        name=${comm##*/}
        name=${name#-}
        case "$allow" in
            *",$name,"*) printf '%s\n' "$name"; exit 0 ;;
        esac
    done
}

notify_stopped() {
    if [ "$(uname -s 2>/dev/null || true)" = Darwin ] && command -v osascript >/dev/null 2>&1; then
        osascript - "$1" "$2" <<'APPLESCRIPT' >/dev/null 2>&1 &
on run argv
  display notification (item 2 of argv) with title ("agent-radar: " & item 1 of argv & " stopped")
end run
APPLESCRIPT
        return 0
    fi

    command -v notify-send >/dev/null 2>&1 || return 0
    notify-send "agent-radar: $1 stopped" "$2" >/dev/null 2>&1 &
}

valid_number() {
    case "$1" in
        ''|*[!0-9]*) return 1 ;;
        *) return 0 ;;
    esac
}

poll_once() {
    now=$(date +%s)
    idle=$(opt @agent-radar-idle-seconds 3)
    valid_number "$idle" || idle=3
    allow=,$(opt @agent-radar-processes 'pi,claude,codex,opencode,aider,cursor'),
    # Working-indicator pattern (ERE, matched byte-wise under LC_ALL=C). Default
    # matches the braille progress glyph (E2 A0-A3 xx = U+2800-U+28FF) that pi/
    # claude/codex animate, OR opencode's 4+-long square progress bar (U+25A0/
    # U+2B1D); neither appears in quoted transcript text.
    work_re=$(opt @agent-radar-working-pattern "$(printf '\342[\240-\243]|(\342\226\240|\342\254\235){4,}')")
    present_panes=$(mktemp "${TMPDIR:-/tmp}/agent-radar.XXXXXX") || exit 1
    records_file=$(mktemp "${TMPDIR:-/tmp}/agent-radar-records.XXXXXX") || exit 1
    "$store_cmd" records > "$records_file"

    tmux list-panes -a -F '#{pane_id}|#{session_name}:#{window_index}.#{pane_index}|#{pane_tty}' 2>/dev/null |
    while IFS='|' read -r pane target tty; do
        agent=$(agent_for_tty "$tty" "$allow" || true)
        [ -n "$agent" ] || continue

        working=0
        if detect_working "$pane"; then working=1; fi
        printf '%s\n' "$pane" >> "$present_panes"

        last=; armed=; state=
        IFS='|' read -r last armed state <<EOF
$(record_hot "$pane")
EOF
        valid_number "$last" || last=$now

        set_pane "$pane" agent "$agent"
        set_pane "$pane" target "$target"

        if [ "$working" = 1 ]; then
            # Agent is visibly working: keep it running and arm the toast so the
            # eventual working->idle transition fires exactly once.
            set_pane "$pane" last_change "$now"
            set_pane "$pane" armed 1
            set_pane "$pane" state working
            set_pane "$pane" stopped_at ""
        elif [ -z "$state" ]; then
            # First sighting and not working: it was already stopped when we
            # arrived, so don't arm — nothing to announce.
            set_pane "$pane" last_change "$now"
            set_pane "$pane" armed 0
            set_pane "$pane" state working
        elif [ $((now - last)) -ge "$idle" ] && [ "$state" != stopped ]; then
            set_pane "$pane" state stopped
            set_pane "$pane" stopped_at "$last"
            # State = stopped for ANY stopped agent pane (the map's definition).
            # The toast is narrower: only a real working->stopped transition (ARMED).
            # ponytail: no active-pane guard — tmux "active pane" != OS focus, so
            # guarding on it swallowed exactly the toasts you want while away. The
            # status segment already covers the "you're here" case (seen-on-focus).
            if [ "${armed:-0}" = 1 ]; then
                notify_stopped "$agent" "$target"
            fi
        fi
    done

    cut -d '|' -f 1 "$records_file" |
    while IFS= read -r pane; do
        [ -n "$pane" ] || continue
        grep -Fx "$pane" "$present_panes" >/dev/null 2>&1 || clear_pane "$pane"
    done

    rm -f "$present_panes" "$records_file"
}

start() {
    existing=$(pid_val)
    if [ -n "$existing" ] && kill -0 "$existing" 2>/dev/null; then
        exit 0
    fi

    pid_set "$$"
    trap 'pid_unset "$$"; exit 0' INT TERM HUP

    while tmux display-message -p '#{pid}' >/dev/null 2>&1; do
        started=$(date +%s)
        poll_once
        interval=$(opt @agent-radar-poll-interval 2)
        valid_number "$interval" || interval=2
        elapsed=$(($(date +%s) - started))
        [ "$elapsed" -lt "$interval" ] && sleep $((interval - elapsed))
    done

    pid_unset "$$"
}

stop() {
    existing=$(pid_val)
    [ -n "$existing" ] && kill "$existing" 2>/dev/null || true
    pid_unset
}

case "${1:-start}" in
    start) start ;;
    once) poll_once ;;
    stop) stop ;;
    restart) stop; start ;;
    *) echo "usage: $0 [start|once|stop|restart]" >&2; exit 2 ;;
esac
