#!/usr/bin/env sh
set -eu

script_dir=$(CDPATH= cd "$(dirname "$0")" && pwd -P) || exit 1
. "$script_dir/agent-radar-record-columns"
eval "$(agent_radar_record_column_vars)"

usage() {
    echo "usage: $0 records | set <pane> <field> <value> | clear <pane>" >&2
    exit 2
}

field_info() {
    want=$1
    field=$(printf '%s' "$2" | tr '[:lower:]' '[:upper:]')
    i=$((agent_radar_record_col_pane + 1))
    for name in $agent_radar_record_fields; do
        if [ "$field" = "$name" ]; then
            [ "$want" = index ] && printf '%s' "$i" || printf '%s' "$name"
            return 0
        fi
        i=$((i + 1))
    done
    return 1
}

key() {
    printf 'TMUX_AGENT_RADAR_PANE_%s_%s' "$1" "$2"
}

env_lines() {
    if [ -n "${AGENT_RADAR_STORE_FILE:-}" ]; then
        cat "$AGENT_RADAR_STORE_FILE"
        return 0
    fi

    command -v tmux >/dev/null 2>&1 || exit 0
    tmux show-environment -g 2>/dev/null || true
}

records() {
    env_lines |
    awk -F= -v fields="$agent_radar_record_fields" '
BEGIN {
    n = split(fields, field_order, " ")
    for (i = 1; i <= n; i++) match_order[i] = field_order[i]
    # Match longer suffixes first: _SEEN_STOPPED_AT must not be eaten as _STOPPED_AT.
    for (i = 1; i <= n; i++) {
        for (j = i + 1; j <= n; j++) {
            if (length(match_order[j]) > length(match_order[i])) {
                tmp = match_order[i]
                match_order[i] = match_order[j]
                match_order[j] = tmp
            }
        }
    }
}
{
    key = $1
    if (key !~ /^TMUX_AGENT_RADAR_PANE_/) next
    val = $0
    sub(/^[^=]*=/, "", val)
    pane = key
    sub(/^TMUX_AGENT_RADAR_PANE_/, "", pane)

    for (i = 1; i <= n; i++) {
        suffix = "_" match_order[i]
        if (pane ~ suffix "$") {
            sub(suffix "$", "", pane)
            value[pane, match_order[i]] = val
            panes[pane] = 1
            next
        }
    }
}
END {
    for (pane in panes) {
        row = pane
        for (i = 1; i <= n; i++)
            row = row "|" value[pane, field_order[i]]
        print row
    }
}' |
    sort -t '|' -k1,1
}

current_from_records() {
    pane=$1
    idx=$2
    awk -F '|' -v pane="$pane" -v idx="$idx" -v col_pane="$agent_radar_record_col_pane" '
$col_pane == pane { print $idx; found = 1; exit }
END { exit found ? 0 : 1 }
' "$AGENT_RADAR_STORE_RECORDS_FILE"
}

current_from_env() {
    name=$1
    env_lines |
    awk -F= -v name="$name" '
$1 == name {
    val = $0
    sub(/^[^=]*=/, "", val)
    print val
    found = 1
    exit
}
END { exit found ? 0 : 1 }
'
}

current_value() {
    pane=$1
    field=$2
    name=$3

    if [ -n "${AGENT_RADAR_STORE_RECORDS_FILE:-}" ] && [ -f "$AGENT_RADAR_STORE_RECORDS_FILE" ]; then
        idx=$(field_info index "$field") || return 1
        current_from_records "$pane" "$idx"
        return $?
    fi

    current_from_env "$name"
}

set_value() {
    [ "$#" -eq 3 ] || usage
    pane=$1
    field=$2
    value=$3
    suffix=$(field_info suffix "$field") || usage
    name=$(key "$pane" "$suffix")

    if current=$(current_value "$pane" "$field" "$name"); then
        [ "$current" = "$value" ] && return 0
    elif [ -z "$value" ]; then
        return 0
    fi

    command -v tmux >/dev/null 2>&1 || exit 0
    if [ -z "$value" ]; then
        tmux set-environment -gu "$name" 2>/dev/null || true
    else
        tmux set-environment -g "$name" "$value"
    fi
}

clear_pane() {
    [ "$#" -eq 1 ] || usage
    pane=$1
    command -v tmux >/dev/null 2>&1 || exit 0
    for suffix in $agent_radar_record_fields; do
        tmux set-environment -gu "$(key "$pane" "$suffix")" 2>/dev/null || true
    done
}

case "${1:-}" in
    records) [ "$#" -eq 1 ] || usage; records ;;
    set) shift; set_value "$@" ;;
    clear) shift; clear_pane "$@" ;;
    *) usage ;;
esac
