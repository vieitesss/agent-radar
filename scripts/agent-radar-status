#!/usr/bin/env sh
set -eu

command -v tmux >/dev/null 2>&1 || exit 0
tmux display-message -p '#{session_name}' >/dev/null 2>&1 || exit 0
script_dir=$(CDPATH= cd "$(dirname "$0")" && pwd -P) || exit 0
store_cmd=$script_dir/agent-radar-store
classify_cmd=$script_dir/agent-radar-classify

current_session=${1:-}
records=$(mktemp "${TMPDIR:-/tmp}/agent-radar-records.XXXXXX") || exit 1
rows=$(mktemp "${TMPDIR:-/tmp}/agent-radar-status.XXXXXX") || exit 1
unseen=$(mktemp "${TMPDIR:-/tmp}/agent-radar-unseen.XXXXXX") || exit 1
unseen_windows=$(mktemp "${TMPDIR:-/tmp}/agent-radar-unseen-windows.XXXXXX") || exit 1
trap 'rm -f "$records" "$rows" "$unseen" "$unseen_windows"' EXIT INT TERM HUP

opt() {
    v=$(tmux show-option -gqv "$1" 2>/dev/null || true)
    [ -n "$v" ] && printf '%s' "$v" || printf '%s' "$2"
}

"$store_cmd" records > "$records"
"$classify_cmd" < "$records" > "$rows"

sync_window_flags() {
    tmux list-windows -a -F '#{session_name}:#{window_index}' 2>/dev/null |
    while IFS= read -r window; do
        [ -n "$window" ] || continue
        tmux set-window-option -t "$window" -qu @agent-radar-window-stopped 2>/dev/null || true
    done

    sort -u "$unseen_windows" |
    while IFS= read -r window; do
        [ -n "$window" ] || continue
        tmux set-window-option -t "$window" -q @agent-radar-window-stopped 1 2>/dev/null || true
    done
}

while IFS='|' read -r tier age sortkey pane agent target state stopped_at seen_at; do
    [ -n "${pane:-}" ] || continue
    session=${target%%:*}

    if [ "$tier" != 1 ] && [ -n "$current_session" ] && [ "$session" = "$current_session" ]; then
        # Dismiss only when the session's focused pane IS the agent pane. Being
        # elsewhere in the session (wrong pane) doesn't mean you've looked at it,
        # so it stays unseen/highlighted until you land on the actual pane.
        active_pane=$(tmux display-message -p -t "$current_session" '#{pane_id}' 2>/dev/null || true)
        if [ "$active_pane" = "$pane" ]; then
            AGENT_RADAR_STORE_RECORDS_FILE=$records "$store_cmd" set "$pane" seen_stopped_at "$stopped_at"
            continue
        fi
    fi

    if [ "$tier" = 0 ]; then
        printf '%s\n' "$session" >> "$unseen"
        printf '%s\n' "${target%.*}" >> "$unseen_windows"
    fi
done < "$rows"

sync_window_flags

if ! grep -q . "$unseen" 2>/dev/null; then
    exit 0
fi

label=$(opt @agent-radar-status-label agents)
color=$(opt @agent-radar-status-color yellow)
out=
sep=

while IFS= read -r session; do
    [ -n "$session" ] || continue
    count=$(grep -Fx "$session" "$unseen" 2>/dev/null | wc -l | tr -d ' ')
    [ "$count" -gt 0 ] || continue

    name=$session
    [ "$count" -gt 1 ] && name="${session}×$count"
    out=${out}${sep}${name}
    sep=' / '
done <<EOF
$(tmux list-sessions -F '#{session_name}' 2>/dev/null || true)
EOF

[ -n "$out" ] || exit 0
printf '#[fg=%s][%s - %s]#[default]' "$color" "$label" "$out"
