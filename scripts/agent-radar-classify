#!/usr/bin/env sh
set -eu

now=${1:-$(date +%s)}
script_dir=$(CDPATH= cd "$(dirname "$0")" && pwd -P) || exit 1
. "$script_dir/agent-radar-record-columns"
eval "$(agent_radar_record_column_vars)"

awk -F '|' \
    -v now="$now" \
    -v col_pane="$agent_radar_record_col_pane" \
    -v col_agent="$agent_radar_record_col_agent" \
    -v col_target="$agent_radar_record_col_target" \
    -v col_state="$agent_radar_record_col_state" \
    -v col_stopped_at="$agent_radar_record_col_stopped_at" \
    -v col_seen_at="$agent_radar_record_col_seen_stopped_at" '
{
    pane = $col_pane
    agent = $col_agent
    target = $col_target
    state = $col_state == "" ? "working" : $col_state
    stopped_at = $col_stopped_at
    seen_at = $col_seen_at
    if (agent == "" || target == "") next

    if (state == "stopped") {
        # seen = focused the pane after it stopped, i.e. SEEN_STOPPED_AT reached
        # STOPPED_AT. The one home for this invariant (CONTEXT seen/unseen model).
        tier = (seen_at == stopped_at) ? 2 : 0
    } else {
        tier = 1
    }

    if (tier == 0 && stopped_at ~ /^[0-9]+$/)
        sortkey = sprintf("%012d", stopped_at)
    else
        sortkey = target

    age = ""
    if (state == "stopped" && stopped_at ~ /^[0-9]+$/) {
        delta = now - stopped_at
        # ponytail: 2h cap past which the exact age stops mattering; raise cap_secs to widen the hours band
        cap_secs = 7200
        if (delta >= cap_secs)   age = "\342\210\236"          # infinity, stopped ages ago
        else if (delta >= 3600)  age = int(delta / 3600) "h"
        else if (delta >= 60)    age = int(delta / 60) "m"
        else                     age = delta "s"
    }

    print tier "|" age "|" sortkey "|" pane "|" agent "|" target "|" state "|" stopped_at "|" seen_at
}'
